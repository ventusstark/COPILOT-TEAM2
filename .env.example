# =============================================
# Todo App environment template
# Framework: Next.js 16 (App Router)
# Database: SQLite (better-sqlite3)
# Auth: WebAuthn + JWT session
# Timezone: Asia/Singapore
# =============================================

# Node environment
NODE_ENV=development

# App URL (used for local callbacks, docs, and future config hooks)
APP_URL=http://127.0.0.1:3000

# JWT (required in production)
# Use a long random value in real environments.
JWT_SECRET=replace-with-a-32-plus-char-random-secret

# Database path override (optional).
# Leave empty to use default project-root todos.db.
# For Railway volume, set this to something like /app/data/todos.db.
SQLITE_DB_PATH=

# Timezone standard used by app/business logic
APP_TIMEZONE=Asia/Singapore

# ---------------------------------------------
# WebAuthn / Passkey settings
# ---------------------------------------------
# Keep RP_ID as your deploy domain host only (no protocol).
RP_ID=127.0.0.1
RP_NAME=Todo App
RP_ORIGIN=http://127.0.0.1:3000

# Optional compatibility aliases if code uses WEBAUTHN_* names
WEBAUTHN_RP_ID=127.0.0.1
WEBAUTHN_RP_NAME=Todo App
WEBAUTHN_ORIGIN=http://127.0.0.1:3000

# ---------------------------------------------
# E2E / automation
# ---------------------------------------------
# Optional Playwright base URL override.
BASE_URL=http://127.0.0.1:3000

# Optional CI flag
CI=false
